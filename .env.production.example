# ─────────────────────────────────────────────────
# Swing Options Bot v2.0 — Environment Config
# OPTIONS TRADING ONLY | Max $100/trade
# ─────────────────────────────────────────────────

# ── Webull API Credentials ──────────────────────
# Get from: https://developer.webull.com/apis/home
WEBULL_APP_KEY=your_app_key
WEBULL_APP_SECRET=your_app_secret
WEBULL_REGION_ID=us
WEBULL_ENVIRONMENT=prod
WEBULL_ACCOUNT_ID=your_account_id

# ── Trade Budget — dynamic (50% of option buying power) ──
# Bot starts at $100; scales up to ABSOLUTE_MAX_BUDGET based on real buying power.
MAX_TRADE_BUDGET=100
ABSOLUTE_MAX_BUDGET=2000

# ── Risk / Daily Loss Limit ─────────────────────
# Scanning halts for the day once cumulative loss reaches this threshold.
MAX_DAILY_LOSS=150
WEBULL_MAX_ORDER_NOTIONAL_USD=5000
WEBULL_MAX_ORDER_QUANTITY=100
WEBULL_SYMBOL_WHITELIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,V,WMT,PG,JNJ,INTC,MA,HD,PFE,KO,MCD,CSCO,NFLX,ADBE,AVGO,CRM,ACN,IBM,VZ,T,XOM,CVX,BAC,GS,MS,C,BLK,SCHW,SPY,QQQ,IWM

# ── Discord Bot (required for YES/NO + commands) ─
# Enable "Message Content Intent" in Discord Developer Portal
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_discord_channel_id
SWING_OPTIONS_DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── Flags ───────────────────────────────────────
TEST_MODE=false
DEBUG_WEBULL=false
