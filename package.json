{
  "name": "swing-options-monitor",
  "version": "2.8.0",
  "description": "Swing options trading bot — Discord-driven, dynamic budget (50% buying power), CALL/PUT only",
  "main": "swing-options-bot.js",
  "type": "commonjs",
  "scripts": {
    "start": "node --env-file=.env.production swing-options-bot.js",
    "start:dev": "TEST_MODE=true node --env-file=.env.production swing-options-bot.js",
    "check": "node --check swing-options-bot.js && node --check webull-integration.js && echo '✅ Syntax OK'",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit.test.js",
    "test:integration": "jest tests/integration.test.js",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "trading",
    "options",
    "swing-trading",
    "discord",
    "automation",
    "webull"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
